<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{% if page.title %}{{ page.title }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ site.description }}">
  <meta name="author" content="{{ site.author }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ site.title }}">
  <meta property="og:description" content="{{ site.description }}">
  <meta property="og:type" content="website">
  {% if site.url %}<meta property="og:url" content="{{ site.url }}">{% endif %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | relative_url }}">
</head>
<body>

<!-- inline SVG icon sprite (no external icon font; faster + offline-friendly) -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <symbol id="i-mail" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></symbol>
    <symbol id="i-linkedin" viewBox="0 0 24 24"><path class="ico-f" d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3-.02-2.97-1.8-2.97-1.82 0-2.1 1.42-2.1 2.88V21H10z"/></symbol>
    <symbol id="i-scholar" viewBox="0 0 24 24"><path d="M12 3 2 9l10 6 10-6-10-6z"/><path d="M6 11v5c0 1.5 3 3 6 3s6-1.5 6-3v-5"/><path d="M22 9v6"/></symbol>
    <symbol id="i-medium" viewBox="0 0 24 24"><path class="ico-f" d="M13.54 12c0 3.04-2.47 5.5-5.52 5.5S2.5 15.04 2.5 12s2.47-5.5 5.52-5.5S13.54 8.96 13.54 12zm6.46 0c0 2.86-1.24 5.18-2.76 5.18-1.52 0-2.76-2.32-2.76-5.18 0-2.86 1.24-5.18 2.76-5.18 1.52 0 2.76 2.32 2.76 5.18zM22 12c0 2.56-.43 4.64-.97 4.64-.54 0-.97-2.08-.97-4.64 0-2.56.43-4.64.97-4.64.54 0 .97 2.08.97 4.64z"/></symbol>
    <symbol id="i-file" viewBox="0 0 24 24"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/></symbol>
    <symbol id="i-pdf" viewBox="0 0 24 24"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/><path d="M9 14h1.5a1.5 1.5 0 0 1 0 3H9zM14 14v3h2M14 15.5h1.5"/></symbol>
    <symbol id="i-book" viewBox="0 0 24 24"><path d="M4 19.5V5a2 2 0 0 1 2-2h13v16H6a2 2 0 0 0-2 2z"/><path d="M6 17h13"/></symbol>
    <symbol id="i-slides" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="13" rx="1.5"/><path d="M9 21h6M12 17v4"/></symbol>
    <symbol id="i-doc" viewBox="0 0 24 24"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6M8 13h8M8 17h5"/></symbol>
    <symbol id="i-ext" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><path d="M15 3h6v6M10 14 21 3"/></symbol>
    <symbol id="i-pin" viewBox="0 0 24 24"><path d="M12 22s7-7.58 7-13a7 7 0 1 0-14 0c0 5.42 7 13 7 13z"/><circle cx="12" cy="9" r="2.5"/></symbol>
    <symbol id="i-user" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.42 3.58-8 8-8s8 3.58 8 8"/></symbol>
  </defs>
</svg>

<nav class="nav">
  <div class="nav-inner">
    <a class="brand" href="{{ '/' | relative_url }}">{{ site.title }}<span class="dot">.</span></a>
    <div class="nav-links">
      <a href="{{ '/' | relative_url }}" {% if page.url == "/" %}class="current"{% endif %}>Home</a>
      {% if site.cv_pdf %}<a href="{{ site.cv_pdf | relative_url }}">Resume</a>{% endif %}
      <a href="{{ '/teaching.html' | relative_url }}" {% if page.url contains 'teaching' %}class="current"{% endif %}>Teaching</a>
      <a href="{{ '/research.html' | relative_url }}" {% if page.url contains 'research' %}class="current"{% endif %}>Research</a>
      {% if site.medium %}<a href="{{ site.medium }}">Medium</a>{% endif %}
    </div>
  </div>
</nav>

{% if page.url == "/" or page.show_hero %}
<section class="hero">
  {% if site.logo %}<img src="{{ site.logo | relative_url }}" alt="{{ site.author }}">{% endif %}
  <div>
    <h1>{{ site.author | default: site.title }}</h1>
    <p class="role"><b>{{ site.tagline_role }}</b>, {{ site.tagline_dept }}<br>{{ site.tagline_school }}</p>
    <div class="icons">
      {% if site.email %}<a href="mailto:{{ site.email }}"><svg class="ico"><use href="#i-mail"/></svg> Email</a>{% endif %}
      {% if site.linkedin %}<a href="{{ site.linkedin }}"><svg class="ico"><use href="#i-linkedin"/></svg> LinkedIn</a>{% endif %}
      {% if site.scholar %}<a href="{{ site.scholar }}"><svg class="ico"><use href="#i-scholar"/></svg> Scholar</a>{% endif %}
      {% if site.medium %}<a href="{{ site.medium }}"><svg class="ico"><use href="#i-medium"/></svg> Medium</a>{% endif %}
      {% if site.cv_pdf %}<a href="{{ site.cv_pdf | relative_url }}"><svg class="ico"><use href="#i-file"/></svg> CV</a>{% endif %}
    </div>
  </div>
</section>
{% endif %}

<main>
{{ content }}
</main>

<footer>
  <span>© {{ 'now' | date: '%Y' }} {{ site.author | default: site.title }}</span>
  <span>Built with Jekyll · Hosted on GitHub Pages</span>
</footer>

</body>
</html>
